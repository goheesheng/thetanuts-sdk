{
  "name": "@thetanuts-finance/thetanuts-client",
  "version": "0.1.2",
  "description": "TypeScript SDK for Thetanuts Finance - Options trading on EVM chains",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "npx tsx scripts/run-mainnet-tests.ts",
    "test:benchmark": "npx tsx scripts/benchmark-indexer.ts",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "thetanuts",
    "options",
    "defi",
    "ethereum",
    "base",
    "sdk",
    "typescript"
  ],
  "author": "Thetanuts Finance",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/thetanuts/sdk.git"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "axios": "^1.7.2",
    "ethers": "^6.0.0",
    "viem": "^2.47.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.2",
    "@typescript-eslint/eslint-plugin": "^7.13.0",
    "@typescript-eslint/parser": "^7.13.0",
    "dotenv": "^17.3.1",
    "eslint": "^8.57.0",
    "tsup": "^8.1.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.5"
  },
  "peerDependencies": {
    "ethers": "^6.0.0"
  },
  "peerDependenciesMeta": {
    "ethers": {
      "optional": false
    }
  }
}
