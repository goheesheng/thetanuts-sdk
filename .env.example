# Thetanuts SDK Testing Environment Variables

# Your wallet private key (without 0x prefix or with - both work)
# WARNING: Never commit your actual private key to git!
PRIVATE_KEY=your_private_key_here

# Optional: Custom RPC URL (defaults to https://mainnet.base.org)
RPC_URL=https://mainnet.base.org

# Optional: Use a premium RPC for better rate limits
# RPC_URL=https://base-mainnet.g.alchemy.com/v2/YOUR_API_KEY
# RPC_URL=https://base-mainnet.infura.io/v3/YOUR_PROJECT_ID
